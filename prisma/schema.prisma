generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

model Participante {
    id       Int    @id @default(autoincrement())
    nome     String
    curso    String
    curso_en String
    fotoUrl  String

    @@map("participante")
}

model Livro {
    id                           Int      @id @default(autoincrement())
    titulo                       String
    capa                         String
    autor                        String
    anoPublicacao                Int
    genero                       String
    genero_en                    String
    resumo                       String
    resumo_en                    String
    contexto                     String
    contexto_en                  String
    enredo                       String
    enredo_en                    String
    detalhesAutor                String
    detalhesAutor_en             String
    estiloEscrita                String
    estiloEscrita_en             String
    verossimilhanca              String
    verossimilhanca_en           String
    caracteristicasLiterarias    String
    caracteristicasLiterarias_en String

    personagens                  String[]
    nota                        Int?

    conclusao                    String
    conclusao_en                 String

    @@map("livro")
}

model Personagem {
    id                 Int    @id @default(autoincrement())
    nome               String
    caracteristicas    String
    caracteristicas_en String
    representacao      String
    representacao_en   String

    @@map("personagem")
}

model Videoaula {
    id           Int    @id @default(autoincrement())
    videoUrl     String
    titulo       String
    titulo_en    String
    descricao    String
    descricao_en String

    @@map("videoaula")
}

model Dica {
    id      Int    @id @default(autoincrement())
    dica    String
    dica_en String

    @@map("dica")
}

model Tema {
    id      Int    @id @default(autoincrement())
    tema    String
    tema_en String

    @@map("tema")
}

model Questao {
    id              Int    @id @default(autoincrement())
    pergunta        String
    pergunta_en     String

    opcaoA          String
    opcaoA_en       String
    opcaoB          String
    opcaoB_en       String
    opcaoC          String
    opcaoC_en       String
    opcaoD          String
    opcaoD_en       String

    respostaCorreta String
    explicacao      String
    explicacao_en   String

    @@map("questao")
}